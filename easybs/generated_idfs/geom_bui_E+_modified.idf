!- Windows Line endings 

Version,
    8.9;                      !- Version Identifier

SIMULATIONCONTROL,
    Yes,                      !- Do Zone Sizing Calculation
    Yes,                      !- Do System Sizing Calculation
    Yes,                      !- Do Plant Sizing Calculation
    Yes,                      !- Run Simulation for Sizing Periods
    Yes,                      !- Run Simulation for Weather File Run Periods
    No,                       !- Do HVAC Sizing Simulation for Sizing Periods
    1;                        !- Maximum Number of HVAC Sizing Simulation Passes

Building,
    None,                     !- Name
    45,                       !- North Axis
    Suburbs,                  !- Terrain
    0.04,                     !- Loads Convergence Tolerance Value
    0.4,                      !- Temperature Convergence Tolerance Value
    FullInteriorAndExterior,    !- Solar Distribution
    25,                       !- Maximum Number of Warmup Days
    6;                        !- Minimum Number of Warmup Days

Timestep,
    1;                        !- Number of Timesteps per Hour

SITE:LOCATION,
    SEOUL.WS_KOR_WMO_471080,    !- Name
    37.571,                   !- Latitude
    126.966,                  !- Longitude
    9,                        !- Time Zone
    87;                       !- Elevation

RunPeriod,
    ,                         !- Name
    1,                        !- Begin Month
    1,                        !- Begin Day of Month
    12,                       !- End Month
    31,                       !- End Day of Month
    Tuesday,                  !- Day of Week for Start Day
    Yes,                      !- Use Weather File Holidays and Special Days
    Yes,                      !- Use Weather File Daylight Saving Period
    No,                       !- Apply Weekend Holiday Rule
    Yes,                      !- Use Weather File Rain Indicators
    Yes;                      !- Use Weather File Snow Indicators

MATERIAL,
    OpaqueWall_Mat,           !- Name
    MediumRough,              !- Roughness
    0.2,                      !- Thickness
    0.1,                      !- Conductivity
    1800,                     !- Density
    900,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    OpaqueRoof_Mat,           !- Name
    MediumRough,              !- Roughness
    0.25,                     !- Thickness
    0.8,                      !- Conductivity
    2000,                     !- Density
    900,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

MATERIAL,
    OpaqueFloor_Mat,          !- Name
    MediumRough,              !- Roughness
    0.25,                     !- Thickness
    1.4,                      !- Conductivity
    2200,                     !- Density
    900,                      !- Specific Heat
    0.9,                      !- Thermal Absorptance
    0.7,                      !- Solar Absorptance
    0.7;                      !- Visible Absorptance

WINDOWMATERIAL:SIMPLEGLAZINGSYSTEM,
    GLZ_Simple_3Wm2K_SHGC60_VT70,    !- Name
    3,                        !- UFactor
    0.6,                      !- Solar Heat Gain Coefficient
    0.7;                      !- Visible Transmittance

CONSTRUCTION,
    WIN_Simple_Clear,         !- Name
    GLZ_Simple_3Wm2K_SHGC60_VT70;    !- Outside Layer

CONSTRUCTION,
    WALL_Const,               !- Name
    OpaqueWall_Mat;           !- Outside Layer

CONSTRUCTION,
    ROOF_Const,               !- Name
    OpaqueRoof_Mat;           !- Outside Layer

CONSTRUCTION,
    FLOOR_Const,              !- Name
    OpaqueFloor_Mat;          !- Outside Layer

GlobalGeometryRules,
    UpperLeftCorner,          !- Starting Vertex Position
    CounterClockWise,         !- Vertex Entry Direction
    Relative;                 !- Coordinate System

ZONE,
    Block TestBlock Storey 0,    !- Name
    0,                        !- Direction of Relative North
    0,                        !- X Origin
    0,                        !- Y Origin
    0,                        !- Z Origin
    1,                        !- Type
    1,                        !- Multiplier
    autocalculate,            !- Ceiling Height
    autocalculate,            !- Volume
    autocalculate,            !- Floor Area
    ,                         !- Zone Inside Convection Algorithm
    ,                         !- Zone Outside Convection Algorithm
    Yes;                      !- Part of Total Floor Area

ZONE,
    Block TestBlock Storey 1,    !- Name
    0,                        !- Direction of Relative North
    0,                        !- X Origin
    0,                        !- Y Origin
    0,                        !- Z Origin
    1,                        !- Type
    1,                        !- Multiplier
    autocalculate,            !- Ceiling Height
    autocalculate,            !- Volume
    autocalculate,            !- Floor Area
    ,                         !- Zone Inside Convection Algorithm
    ,                         !- Zone Outside Convection Algorithm
    Yes;                      !- Part of Total Floor Area

ZONE,
    Block TestBlock Storey 2,    !- Name
    0,                        !- Direction of Relative North
    0,                        !- X Origin
    0,                        !- Y Origin
    0,                        !- Z Origin
    1,                        !- Type
    1,                        !- Multiplier
    autocalculate,            !- Ceiling Height
    autocalculate,            !- Volume
    autocalculate,            !- Floor Area
    ,                         !- Zone Inside Convection Algorithm
    ,                         !- Zone Outside Convection Algorithm
    Yes;                      !- Part of Total Floor Area

